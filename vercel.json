{
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "api/telegram/sample.png"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
