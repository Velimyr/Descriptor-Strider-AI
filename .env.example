# Приклад змінних середовища. Скопіюйте у .env.local і заповніть значеннями.
# НЕ комітьте реальні секрети — .env.local в .gitignore.

# Google OAuth (експорт у Google Sheets)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_URL=

# Telegram-бот
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_WEBHOOK_SECRET=
# Секрет для зовнішнього cron-тригера (GitHub Actions → /api/telegram/cron/*)
TELEGRAM_CRON_SECRET=
TELEGRAM_ADMIN_LOGIN=
TELEGRAM_ADMIN_PASSWORD=

# Supabase (service_role key — повний доступ)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Префікс таблиць: botdev_ для dev/staging, порожньо для prod.
# TABLE_PREFIX=

# Шифрування Gemini-ключів користувачів (BYOK AI-розпізнавання)
USER_KEY_ENC_SECRET=

# Система «Карма» Генеалогічного навігатора (uagenealogy.com).
# Bearer-токен для /api/karma/link-redeem (команда /linknavigator) і /api/karma/ingest
# (нічна синхронізація балів). Видається адміністратором Навігатора.
KARMA_TOKEN=
